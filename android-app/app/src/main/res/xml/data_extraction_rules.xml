<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ 数据提取规则 -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="content_backup.md" />
        <include domain="sharedpref" path="makemdown_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="content_backup.md" />
        <include domain="sharedpref" path="makemdown_prefs.xml" />
    </device-transfer>
</data-extraction-rules>