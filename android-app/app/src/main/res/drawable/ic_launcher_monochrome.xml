<?xml version="1.0" encoding="utf-8"?>
<!-- 应用启动图标 - monochrome 主题图标层 v1.0.14
     Android 13+ 主题图标(Themed Icon)专用。
     系统会取本图层的 alpha 通道作为 mask,忽略颜色,用系统主题色重新填充。
     重要: monochrome 下只画"主体形状" + 镂空 —— 不要画多色叠加,
           否则主题色会把所有 alpha>0 区域填成同色,看不出任何形状。
     设计: 文档卡片(实心主题色),M 字母挖空(透明)——
           主题图标下显示成一个"主题色文档,中间镂空 M"。
     居中: 与前景层 v1.0.14 对齐,文档卡片 + M 中心都在 (512, 512)。
     形状全部在 66dp 安全区(半径 330,中心 512)内。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="1024"
    android:viewportHeight="1024">

    <!-- 文档卡片(实心,主题色填充的块面) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M314,304 L616,304 L710,398 L710,670 Q710,720 660,720 L364,720 Q314,720 314,670 Z" />

    <!-- 折角(同主题色,半透明 → alpha 通道 0.7,看起来"柔和"一些) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.7"
        android:pathData="M616,304 L710,398 L616,398 Z" />

    <!-- M 字母(镂空:用 evenodd fillType 制造"洞")
         monochrome 下颜色被忽略,只关心 alpha:
         - 文档卡片 alpha=1 → 主题色
         - M 字母通过 evenodd "挖洞" → 镂空主题色背景
         在主题图标下显示: 一个主题色文档,中间一个 M 形状的"洞" -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M314,304 L616,304 L710,398 L710,670 Q710,720 660,720 L364,720 Q314,720 314,670 Z M386,630.5 L386,446.5 L440,446.5 L512,531.5 L584,446.5 L638,446.5 L638,630.5 L596,630.5 L596,509.5 L530,583.5 L494,583.5 L428,509.5 L428,630.5 Z" />

</vector>
