<?xml version="1.0" encoding="utf-8"?>
<!-- 夜间模式启动页背景
     修复 B34 续: 同 drawable/splash_background.xml,
     <bitmap> 引用 @mipmap/ic_launcher 在 Android 8+ 会因 adaptive-icon
     inflate 失败导致启动闪退。改为直接引用 vector drawable。 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/splash_bg_dark" />
    <item
        android:width="180dp"
        android:height="180dp"
        android:gravity="center"
        android:drawable="@drawable/ic_launcher_foreground" />
</layer-list>
