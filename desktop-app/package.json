{
  "name": "markdoc",
  "version": "1.0.9",
  "description": "马克档 · Markdown Mobile Browser (桌面版)",
  "main": "src/main.js",
  "author": {
    "name": "LiuHua",
    "email": "liuhua1202@users.noreply.github.com"
  },
  "homepage": "https://github.com/liuhua1202/markdoc#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/liuhua1202/markdoc.git"
  },
  "bugs": {
    "url": "https://github.com/liuhua1202/markdoc/issues"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.markdoc.app",
    "productName": "马克档",
    "copyright": "Copyright © 2026 马克档",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "!src/assets/*.svg.map",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets"
      }
    ],

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "publisherName": "马克档",
      "verifyUpdateCodeSignature": false
    },

    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",

      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright © 2026 马克档",
        "LSApplicationCategoryType": "public.app-category.productivity"
      },

      "notarize": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },

    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    },

    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Office",
      "artifactName": "${productName}-${version}.${ext}",
      "maintainer": "LiuHua <liuhua1202@users.noreply.github.com>",
      "vendor": "markdoc"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "马克档"
    },

    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}